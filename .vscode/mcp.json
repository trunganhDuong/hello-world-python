{
	"servers": {
		"github": {
			"command": "npx",
			"args": [
				"-y",
				"@modelcontextprotocol/server-github@2025.4.8"
			],
			"env": {
				"GITHUB_PERSONAL_ACCESS_TOKEN": "${input:github_token}"
			},
			"type": "stdio"
		}
	},
	"inputs": [
		{
			"id": "github_token",
			"type": "promptString",
			"description": "Enter your GitHub Personal Access Token"
		}
	]
}